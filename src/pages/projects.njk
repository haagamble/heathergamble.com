---
layout: base
title: Projects
description: Projects I am building and sharing.
permalink: /projects/
---

<h1>Projects</h1>
<p class="lede">A growing collection of language-learning projects, tools, and experiments.</p>

<div class="project-grid">
  {%- for project in collections.projects -%}
    <a class="project-card" href="{{ project.url }}">
      <div class="project-card-top">
        <h2>{{ project.data.title }}</h2>
        {%- if project.data.status -%}
          <span class="project-status">{{ project.data.status }}</span>
        {%- endif -%}
      </div>

      {%- if project.data.type -%}
        <p class="project-type">{{ project.data.type }}</p>
      {%- endif -%}

      {%- if project.data.summary -%}
        <p>{{ project.data.summary }}</p>
      {%- endif -%}

      <p class="project-read">View project details -></p>
    </a>
  {%- endfor -%}
</div>
