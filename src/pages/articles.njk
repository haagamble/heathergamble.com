<h1>Articles</h1>
<p class="lede">Practical language-learning activities and frameworks you can use with any language.</p>

{% set sections = [
  {
    title: "Start Here",
    slugs: ["eclectic-language-learning"]
  },
  {
    title: "Practical Techniques",
    slugs: [
      "using-flashcards",
      "using-a-photo-book-for-language-learning",
      "substitution-drills"
    ]
  },
  {
    title: "Learning from Everyday Life",
    slugs: ["reading-signs"]
  },
  {
    title: "Ideas / Concepts",
    slugs: ["glue"]
  }
] %}

{% for section in sections %}
  <section class="article-section">
    <h2>{{ section.title }}</h2>
    <ul class="article-links">
      {% for slug in section.slugs %}
        {% for item in collections.articles %}
          {% if item.fileSlug == slug %}
            <li><a href="{{ item.url }}">{{ item.data.navTitle }}</a></li>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </ul>
  </section>
{% endfor %}