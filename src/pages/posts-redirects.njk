---
pagination:
  data: collections.diary
  size: 1
  alias: post
permalink: "/posts/{{ post.fileSlug }}/index.html"
eleventyExcludeFromCollections: true
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0;url={{ post.url }}" />
    <link rel="canonical" href="{{ post.url }}" />
    <title>Redirecting...</title>
  </head>
  <body>
    <p>Redirecting to <a href="{{ post.url }}">{{ post.url }}</a>.</p>
  </body>
</html>
