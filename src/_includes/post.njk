---
layout: base
---

<article class="post">
  <header class="post-header">
    <h1 class="post-h1">
      <span class="day-badge">Day {{ date | learningDay }}</span>
      {{ title }}
    </h1>
    <p class="post-meta">
      <span class="post-date">{{ date | readableDate }}</span>
      {%- if summary -%}
        <span class="post-dot">&bull;</span>
        <span class="post-summary">{{ summary }}</span>
      {%- endif -%}
    </p>

    {%- set postTags = tags | visibleTags -%}
    {%- if postTags.length -%}
      <p class="post-tags">
        <span class="post-tags-label">Tags:</span>
        {%- for tag in postTags -%}
          <a class="tag-link" href="/diary/?tag={{ tag }}">{{ tag | formatTag }}</a>{% if not loop.last %}<span class="tag-separator">&bull;</span>{% endif %}
        {%- endfor -%}
      </p>
    {%- endif -%}
  </header>

  <div class="post-content">
    {{ content | safe }}
  </div>

  <nav class="post-nav">
    <a href="/diary/">&larr; Back to diary</a>
    <a href="/">Home</a>
  </nav>
</article>